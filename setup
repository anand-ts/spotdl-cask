#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${ROOT_DIR}"

if ! command -v uv >/dev/null 2>&1; then
    echo "Missing 'uv'. Install it from https://docs.astral.sh/uv/getting-started/installation/"
    exit 1
fi

export UV_CACHE_DIR="${ROOT_DIR}/.uv-cache"

exec uv sync "$@"
